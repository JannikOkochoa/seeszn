# ─── Email delivery (Resend) ──────────────────────────────────────────────────
# Required for the Sichtbarkeitsprüfung delivery. The free scan works without it;
# only the full-diagnosis email + internal lead need these.
RESEND_API_KEY=
SEESZN_LEAD_EMAIL=elana@seeszn.com
SEESZN_FROM_EMAIL="Elana von SEESZN <elana@seeszn.com>"
SEESZN_REPLY_TO_EMAIL=elana@seeszn.com

# ─── KI-Antwortfragen — Web-Signalcheck ───────────────────────────────────────
# AI_ANSWER_PROVIDER=none      generates the 3 KI-Antwortfragen without any live
#                              web checks (questions returned with checked=false).
# AI_ANSWER_PROVIDER=google_cse runs exactly 3 Google Custom Search queries per
#                              scan, one per question. This is a Web-Signalcheck of
#                              the visible web surface, NOT a live ChatGPT, Gemini,
#                              Perplexity or Google AI Overview ranking.
AI_ANSWER_PROVIDER=none
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=

# ─── Brief-request webhook (optional) ────────────────────────────────────────
# POST target for /api/brief-request submissions (e.g. a Make/Zapier webhook or
# your own endpoint). If unset, submissions are logged server-side but not forwarded.
BRIEF_REQUEST_WEBHOOK_URL=

# ─── Client Rooms ─────────────────────────────────────────────────────────────
# Zugangspasswort für den privaten Klühspies-Raum (/kluehspies-room).
# Ohne Env-Variable greift der markierte Übergangs-Fallback im Code.
KLUEHSPIES_ROOM_PASSWORD=

# ─── Entwicklung: Team-Bootstrap ──────────────────────────────────────────────
# Passwort der example.com-Testkonten aus scripts/dev-bootstrap-team.mjs.
# Nur lokal/Dev setzen; niemals ein echtes Passwort committen. Fehlt die
# Variable, bricht das Bootstrap-Script bewusst ab.
DEV_BOOTSTRAP_PASSWORD=

# ─── Optional ─────────────────────────────────────────────────────────────────
# Free PageSpeed Insights signal for the scan (best effort, never blocks a scan).
PAGESPEED_API_KEY=
